{
  "expo": {
    "name": "Jai Shri Ram",
    "slug": "japa-counter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF3E3"
    },
    "android": {
