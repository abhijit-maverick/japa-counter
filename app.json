        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FDF3E3"
      },
      "package": "com.jaishriram.japacounter",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-av"
    ],
    "scheme": "japacounter",
    "extra": {
      "eas": {
        "projectId": "5ad62d3e-8071-481b-a4e2-0567088baaa7"
      }
    }
  }
}
